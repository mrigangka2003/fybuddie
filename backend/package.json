{
  "name": "personal-finance-tracker-backend",
  "version": "1.0.0",
  "description": "Personal Finance Tracker Backend API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker/index.ts",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "5.7.1",
    "bcrypt": "5.1.1",
    "bullmq": "4.14.0",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.5",
    "csv-stringify": "6.4.4",
    "date-fns": "3.0.6",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "prisma": "5.7.1",
    "socket.io": "4.7.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.5",
    "@types/node": "20.10.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "1.1.0",
    "fast-check": "3.14.0",
    "tsx": "4.6.2",
    "typescript": "5.3.3",
    "vitest": "1.1.0"
  }
}
